<style>
  .urgency { background: #111; padding: 40px 48px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 24px; }
  .urg-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: #f0a500; margin-bottom: 10px; font-family: 'Rajdhani', sans-serif; }
  .urg-title { font-size: 24px; font-weight: 400; color: #fff; margin-bottom: 6px; font-family: 'Rajdhani', sans-serif; }
  .urg-sub { font-size: 13px; color: #666; font-family: 'Rajdhani', sans-serif; }
  .timer { display: flex; gap: 16px; align-items: center; }
  .timer-block { text-align: center; background: #1a1a1a; padding: 16px 20px; border: 1px solid #333; }
  .timer-num { font-size: 28px; font-weight: 500; color: #f0a500; display: block; font-family: 'Rajdhani', sans-serif; }
  .timer-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: #555; display: block; margin-top: 4px; font-family: 'Rajdhani', sans-serif; }
  .timer-sep { font-size: 24px; color: #333; }

  .why { padding: 60px 48px; background: #fafafa; }
  .why-head { margin-bottom: 40px; }
  .why-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: #f0a500; margin-bottom: 8px; font-family: 'Rajdhani', sans-serif; }
  .why-title { font-size: 26px; font-weight: 400; font-family: 'Rajdhani', sans-serif; }
  .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .why-card { text-align: center; padding: 32px 24px; background: #fff; border: 1px solid #ebebeb; }
  .why-icon { font-size: 36px; margin-bottom: 16px; }
  .why-card-title { font-size: 15px; font-weight: 600; margin-bottom: 10px; font-family: 'Rajdhani', sans-serif; }
  .why-desc { font-size: 13px; color: #888; line-height: 1.7; font-family: 'Rajdhani', sans-serif; }

  .reviews { padding: 60px 48px; }
  .reviews-head { margin-bottom: 40px; }
  .reviews-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: #f0a500; margin-bottom: 8px; font-family: 'Rajdhani', sans-serif; }
  .reviews-title { font-size: 26px; font-weight: 400; font-family: 'Rajdhani', sans-serif; }
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .review-card { background: #fafafa; border: 1px solid #ebebeb; padding: 24px; }
  .review-stars { color: #f0a500; font-size: 14px; margin-bottom: 12px; }
  .review-text { font-size: 13px; color: #555; line-height: 1.7; margin-bottom: 16px; font-style: italic; font-family: 'Rajdhani', sans-serif; }
  .review-author { display: flex; align-items: center; gap: 10px; }
  .review-avatar { width: 36px; height: 36px; border-radius: 50%; background: #f0a500; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: #fff; flex-shrink: 0; font-family: 'Rajdhani', sans-serif; }
  .review-name { font-size: 13px; font-weight: 600; font-family: 'Rajdhani', sans-serif; }
  .review-date { font-size: 11px; color: #bbb; font-family: 'Rajdhani', sans-serif; }

  .newsletter { background: #f0a500; padding: 60px 48px; text-align: center; }
  .nl-title { font-size: 28px; font-weight: 400; color: #111; margin-bottom: 10px; font-family: 'Rajdhani', sans-serif; }
  .nl-sub { font-size: 14px; color: rgba(0,0,0,0.6); margin-bottom: 28px; font-family: 'Rajdhani', sans-serif; }
  .nl-form { display: flex; max-width: 480px; margin: 0 auto; }
  .nl-input { flex: 1; padding: 14px 20px; border: none; font-size: 13px; outline: none; font-family: 'Rajdhani', sans-serif; }
  .nl-btn { background: #111; color: #fff; padding: 14px 24px; border: none; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; font-family: 'Rajdhani', sans-serif; }

  .footer { background: #111; padding: 48px 48px 24px; }
  .footer__inner { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 40px; margin-bottom: 40px; }
  .footer__logo-flash { font-size: 18px; font-weight: 700; color: #fff; letter-spacing: 2px; font-family: 'Rajdhani', sans-serif; }
  .footer__logo-volt { font-size: 12px; color: #f0a500; letter-spacing: 4px; margin-bottom: 14px; font-family: 'Rajdhani', sans-serif; }
  .footer__desc { font-size: 12px; color: #555; line-height: 1.9; font-family: 'Rajdhani', sans-serif; }
  .footer__col-title { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: #fff; margin-bottom: 16px; font-family: 'Rajdhani', sans-serif; }
  .footer__links { list-style: none; padding: 0; margin: 0; }
  .footer__links a { display: block; font-size: 12px; color: #555; text-decoration: none; margin-bottom: 9px; font-family: 'Rajdhani', sans-serif; transition: color 0.2s; }
  .footer__links a:hover { color: #f0a500; }
  .footer__bottom { padding-top: 22px; border-top: 1px solid #222; }
  .footer__copy { font-size: 11px; color: #333; font-family: 'Rajdhani', sans-serif; }

  @media (max-width: 768px) {
    .urgency { flex-direction: column; text-align: center; padding: 32px 20px; }
    .why-grid, .reviews-grid, .footer__inner { grid-template-columns: 1fr; }
    .why, .reviews, .fp, .newsletter, .footer { padding: 40px 20px; }
  }
</style>

<div class="urgency">
  <div>
    <div class="urg-label">{{ section.settings.offer_label }}</div>
    <div class="urg-title">{{ section.settings.offer_title }}</div>
    <div class="urg-sub">{{ section.settings.offer_sub }}</div>
  </div>
  <div class="timer">
    <div class="timer-block"><span class="timer-num" id="fv-h">08</span><span class="timer-label">Horas</span></div>
    <span class="timer-sep">:</span>
    <div class="timer-block"><span class="timer-num" id="fv-m">34</span><span class="timer-label">Minutos</span></div>
    <span class="timer-sep">:</span>
    <div class="timer-block"><span class="timer-num" id="fv-s">21</span><span class="timer-label">Segundos</span></div>
  </div>
</div>

<div class="why">
  <div class="why-head">
    <div class="why-label">Nuestra promesa</div>
    <div class="why-title">¿Por qué elegirnos?</div>
  </div>
  <div class="why-grid">
    <div class="why-card"><div class="why-icon">🏆</div><div class="why-card-title">Calidad garantizada</div><div class="why-desc">Todos nuestros productos pasan controles de calidad estrictos antes de llegar a ti.</div></div>
    <div class="why-card"><div class="why-icon">🌍</div><div class="why-card-title">Envíos a Europa</div><div class="why-desc">Enviamos a más de 20 países europeos con seguimiento en tiempo real.</div></div>
    <div class="why-card"><div class="why-icon">❤️</div><div class="why-card-title">Clientes satisfechos</div><div class="why-desc">Más de 5.000 clientes felices con una valoración media de 4.8 estrellas.</div></div>
  </div>
</div>

<div class="reviews">
  <div class="reviews-head">
    <div class="reviews-label">Opiniones</div>
    <div class="reviews-title">Lo que dicen nuestros clientes</div>
  </div>
  <div class="reviews-grid">
    <div class="review-card"><div class="review-stars">★★★★★</div><div class="review-text">"La tira LED es increíble, la calidad es mucho mejor de lo que esperaba. La instalé en el salón y queda espectacular."</div><div class="review-author"><div class="review-avatar">MG</div><div><div class="review-name">María G.</div><div class="review-date">Madrid · hace 2 semanas</div></div></div></div>
    <div class="review-card"><div class="review-stars">★★★★★</div><div class="review-text">"El aplique nórdico llegó perfectamente embalado. La instalación fue muy fácil y la calidad del metal es excelente."</div><div class="review-author"><div class="review-avatar">JR</div><div><div class="review-name">Juan R.</div><div class="review-date">Barcelona · hace 1 mes</div></div></div></div>
    <div class="review-card"><div class="review-stars">★★★★☆</div><div class="review-text">"El detector de voltaje funciona perfectamente. Muy útil para el trabajo. El envío tardó 10 días, dentro del plazo."</div><div class="review-author"><div class="review-avatar">PL</div><div><div class="review-name">Pedro L.</div><div class="review-date">Valencia · hace 3 semanas</div></div></div></div>
  </div>
</div>

<div class="newsletter">
  <div class="nl-title">{{ section.settings.nl_title }}</div>
  <div class="nl-sub">{{ section.settings.nl_sub }}</div>
  <div class="nl-form">
    <input class="nl-input" type="email" placeholder="Tu email aquí...">
    <button class="nl-btn">Suscribirme</button>
  </div>
</div>

<footer class="footer">
  <div class="footer__inner">
    <div>
      <div class="footer__logo-flash">FLASHVOLT</div>
      <div class="footer__logo-volt">VOLT</div>
      <div class="footer__desc">{{ section.settings.description }}</div>
    </div>
    <div>
      <div class="footer__col-title">Tienda</div>
      <ul class="footer__links">
        {% for link in linklists[section.settings.col_1_menu].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    <div>
      <div class="footer__col-title">Ayuda</div>
      <ul class="footer__links">
        {% for link in linklists[section.settings.col_2_menu].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="footer__bottom">
    <div class="footer__copy">&copy; {{ 'now' | date: '%Y' }} FLASHVOLT. Todos los derechos reservados.</div>
  </div>
</footer>

<script>
  let fvTotal = 8*3600+34*60+21;
  setInterval(function(){
    if(fvTotal<=0)return;
    fvTotal--;
    const h=Math.floor(fvTotal/3600),m=Math.floor((fvTotal%3600)/60),s=fvTotal%60;
    document.getElementById('fv-h').textContent=String(h).padStart(2,'0');
    document.getElementById('fv-m').textContent=String(m).padStart(2,'0');
    document.getElementById('fv-s').textContent=String(s).padStart(2,'0');
  },1000);
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "offer_label", "label": "Etiqueta oferta", "default": "Oferta especial" },
    { "type": "text", "id": "offer_title", "label": "Título oferta", "default": "10% de descuento hoy" },
    { "type": "text", "id": "offer_sub", "label": "Subtítulo oferta", "default": "Usa el código FLASH10 al pagar" },
    { "type": "text", "id": "nl_title", "label": "Título newsletter", "default": "10% de descuento en tu primer pedido" },
    { "type": "text", "id": "nl_sub", "label": "Subtítulo newsletter", "default": "Suscríbete y recibe ofertas exclusivas en tu email" },
    { "type": "textarea", "id": "description", "label": "Descripción footer", "default": "Iluminación y herramientas eléctricas de calidad. Envíos a toda Europa desde España." },
    { "type": "link_list", "id": "col_1_menu", "label": "Menú columna 1" },
    { "type": "link_list", "id": "col_2_menu", "label": "Menú columna 2" }
  ]
}
{% endschema %}